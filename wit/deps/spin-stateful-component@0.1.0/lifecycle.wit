package spin:stateful-component@0.1.0;

/// Lifecycle hooks exported by every stateful component.
interface lifecycle {
  /// Called when the instance is instantiated. The component receives its
  /// unique ID and should restore any needed state from its storage.
  instantiate: func(id: string);

  /// Called before the instance is suspended (idle timeout or migration).
  /// The component should flush any pending state.
  suspend: func();
}
